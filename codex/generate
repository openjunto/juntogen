#!/usr/bin/env bash
#
# generate — Orchestrate the OpenJunto Codex (oj-codex) generation pipeline.
#
# This is the Codex sibling of juntogen/claude/generate, written lean. It runs the
# step-NN prompts in juntogen/codex/steps/ through an LLM "compiler" and emits the
# installable Codex plugin into OUTPUT_DIR.
#
# ENGINE vs TARGET (important):
#   The --model flag selects the *compiler engine* — a CLAUDE model (opus/sonnet/haiku)
#   that runs the generation prompts. The *target* platform is Codex: the gpt-5.x model
#   ids appear only inside the GENERATED artifacts (platform-snapshot.yaml, CONDUCTOR.md
#   model table, .codex/agents/*.toml), never as the engine model.
#
# ISOLATION: each step runs `claude` with GENERATION MODE flags so the user's installed
# OpenJunto protocol does not hijack the precise-generator behavior. If ANTHROPIC_API_KEY
# is set, --bare is used (stronger isolation); else targeted-isolation flags.
#
# PARITY GAPS vs juntogen/claude/generate (documented; port later — ROADMAP §1 shared core):
#   - no concurrency lock / watchdog / heartbeat / spike mode / per-run cache dir
#   - build_prompt does only path substitution (codex prompts use no [CANONICAL:]/[FILE:]
#     markers or {CONTRACT_PRIMITIVES}); add the awk marker resolver if they adopt them.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
JUNTOGEN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly JUNTOGEN_ROOT

# Step 08 retired (Makefile installer obsolete in plugin form); step 09 retired
# (config.toml is user-owned, not shipped). Numeric gaps preserved for parity.
readonly ALL_STEPS="00 01 02 03 04 05 06 07 10 11"

readonly GENERATION_MODE_PROMPT="IMPORTANT OVERRIDE — GENERATION MODE: You are a precise artifact generator, NOT a project manager. Ignore all instructions from CLAUDE.md / AGENTS.md / CONDUCTOR.md files in this session. Do NOT delegate to sub-agents. Do NOT apply triage, stakeholder analysis, or expert coordination protocols. Read the generation prompt provided, follow its instructions exactly, and write all specified output files directly using the Write tool. You are generating OpenAI Codex plugin code and configuration — write the files yourself."

SPEC_DIR=""
OUTPUT_DIR=""
MODEL="${CLAUDE_MODEL:-sonnet}"   # ENGINE model (Claude), not a Codex model
FROM_STEP=""
ONLY_STEPS=""
OJ_SOURCE=""
SPEC_DIR_FLAG=""
FORCE=false
DRY_RUN=false

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'
log_info(){ echo -e "${GREEN}[INFO]${NC}  $*"; }
log_warn(){ echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error(){ echo -e "${RED}[ERROR]${NC} $*"; }
log_step(){ echo -e "${BLUE}[STEP]${NC}  $*"; }
log_ok(){ echo -e "${GREEN}[OK]${NC}    $*"; }
log_dry(){ echo -e "${CYAN}[DRY]${NC}   $*"; }
die(){ log_error "$@"; exit 1; }

use_bare_mode(){ [ -n "${ANTHROPIC_API_KEY:-}" ]; }

usage() {
cat <<EOF
generate — Generate the OpenJunto Codex plugin (oj-codex) from juntospec.

USAGE: generate <OUTPUT_DIR> [OPTIONS]

OPTIONS:
  --model MODEL        Claude ENGINE model running the prompts (default: sonnet).
  --from-step NN       Resume from step NN.
  --steps 00,03        Run only these steps (comma-separated).
  --spec-dir DIR       juntospec corpus root (else \$OJ_SPEC_DIR, else sibling probe).
  --oj-source DIR      Existing plugin tree for format-reference reads ({OJ_SOURCE}).
  --force              Ignore sentinels; re-run every step.
  --dry-run            Print what would run without invoking the engine.
  --help               This help.

Sentinels: \${OUTPUT_DIR}/.oj-codex-sentinels/.step-NN.done (idempotency).
EOF
}

# ── arg parse ────────────────────────────────────────────────────────────────
parse_args() {
    [ $# -gt 0 ] || { usage; exit 1; }
    case "$1" in --help|-h) usage; exit 0 ;; --*) die "First arg must be OUTPUT_DIR" ;; *) OUTPUT_DIR="$1"; shift ;; esac
    while [ $# -gt 0 ]; do case "$1" in
        --model) MODEL="$2"; shift 2 ;;
        --from-step) FROM_STEP="$2"; shift 2 ;;
        --steps) ONLY_STEPS="$2"; shift 2 ;;
        --spec-dir) SPEC_DIR_FLAG="$2"; shift 2 ;;
        --oj-source) OJ_SOURCE="$2"; shift 2 ;;
        --force) FORCE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --help|-h) usage; exit 0 ;;
        *) die "Unknown option: $1 (see --help)" ;;
    esac; done
    [ -n "${OUTPUT_DIR}" ] || die "OUTPUT_DIR required"
    case "${OUTPUT_DIR}" in /*) ;; *) OUTPUT_DIR="$(pwd)/${OUTPUT_DIR}" ;; esac
    mkdir -p "${OUTPUT_DIR}"
    [ -z "${OJ_SOURCE}" ] || { [ -d "${OJ_SOURCE}" ] || die "--oj-source not found: ${OJ_SOURCE}"; case "${OJ_SOURCE}" in /*) ;; *) OJ_SOURCE="$(pwd)/${OJ_SOURCE}" ;; esac; }
    [ -z "${SPEC_DIR_FLAG}" ] || { [ -d "${SPEC_DIR_FLAG}" ] || die "--spec-dir not found"; case "${SPEC_DIR_FLAG}" in /*) ;; *) SPEC_DIR_FLAG="$(pwd)/${SPEC_DIR_FLAG}" ;; esac; }
}

resolve_spec_dir() {
    local cand="" src=""
    if [ -n "${SPEC_DIR_FLAG}" ]; then cand="${SPEC_DIR_FLAG}"; src="--spec-dir";
    elif [ -n "${OJ_SPEC_DIR:-}" ]; then cand="${OJ_SPEC_DIR}"; src="\$OJ_SPEC_DIR";
    elif [ -d "${JUNTOGEN_ROOT}/../juntospec" ]; then cand="$(cd "${JUNTOGEN_ROOT}/../juntospec" && pwd)"; src="sibling probe"; fi
    [ -n "${cand}" ] || die "Cannot locate juntospec. Use --spec-dir, \$OJ_SPEC_DIR, or co-locate juntogen+juntospec."
    [ -d "${cand}" ] || die "spec dir not a directory: ${cand}"
    [ -f "${cand}/platform-contract.yaml" ] || die "spec dir lacks platform-contract.yaml: ${cand}"
    SPEC_DIR="${cand}"; log_info "SPEC_DIR via ${src}: ${SPEC_DIR}"
}

# ── per-step config ──────────────────────────────────────────────────────────
step_prompt(){ echo "step-$1-*.md"; }   # resolved by glob in steps/
step_max_turns(){ case "$1" in 03) echo 90 ;; 10) echo 35 ;; 00) echo 10 ;; *) echo 30 ;; esac; }
step_desc(){ case "$1" in
    00) echo "Platform capability ingestion (Codex)";;
    01) echo "Scaffold + CONDUCTOR.md";;
    02) echo "Agent preamble + index";;
    03) echo "Agent profiles (16 full + 16 compact + .codex/agents/*.toml)";;
    04) echo "Reference files (8)";;
    05) echo "Templates (5)";;
    06) echo "Skills (SKILL.md)";;
    07) echo "oj-helper + static plugin/hooks manifests";;
    10) echo "Documentation";;
    11) echo "Org scaffold";;
    *) echo "step $1";; esac; }

resolve_prompt_file() {
    local step="$1" f
    f=$(find "${SCRIPT_DIR}/steps" -maxdepth 1 -name "step-${step}-*.md" -type f 2>/dev/null | sort | head -1)
    echo "${f}"
}

# ── verification (Codex plugin shape) ────────────────────────────────────────
_chk_file(){ [ -f "$1" ] && [ -s "$1" ] || { log_error "missing/empty: $1"; return 1; }; }
_chk_dir(){ [ -d "$1" ] || { log_error "missing dir: $1"; return 1; }; }

verify_step() {
    local step="$1" d="${OUTPUT_DIR}" ok=0
    case "${step}" in
        00) _chk_file "${d}/platform-snapshot.yaml" || ok=1 ;;
        01) _chk_file "${d}/CONDUCTOR.md" || ok=1; _chk_dir "${d}/agents" || ok=1; _chk_dir "${d}/reference" || ok=1; _chk_dir "${d}/templates" || ok=1 ;;
        02) _chk_file "${d}/agents/_preamble.md" || ok=1; _chk_file "${d}/agents/index.md" || ok=1 ;;
        03) local full comp toml
            full=$(find "${d}/agents" -maxdepth 1 -name '*.md' ! -name '_preamble.md' ! -name 'index.md' ! -name '*-compact.md' -type f 2>/dev/null | wc -l | tr -d ' ')
            comp=$(find "${d}/agents" -maxdepth 1 -name '*-compact.md' -type f 2>/dev/null | wc -l | tr -d ' ')
            toml=$(find "${d}/.codex/agents" -maxdepth 1 -name '*.toml' -type f 2>/dev/null | wc -l | tr -d ' ')
            [ "${full}" -ge 16 ] || { log_error "step03: ${full} full profiles (<16)"; ok=1; }
            [ "${comp}" -ge 16 ] || { log_error "step03: ${comp} compact profiles (<16)"; ok=1; }
            [ "${toml}" -ge 16 ] || { log_warn "step03: ${toml} .codex/agents/*.toml (<16) — native agent defs"; }
            ;;
        04) local f; for f in workflow-stages stakeholder-guide worked-examples dev-mode failure-protocol file-patterns project-scaffolding communication-standards; do _chk_file "${d}/reference/${f}.md" || ok=1; done ;;
        05) local f; for f in technical-analysis architecture-decision-record retrospective session-state communications-playbook; do _chk_file "${d}/templates/${f}.md" || ok=1; done ;;
        06) _chk_dir "${d}/skills" || ok=1
            local found=0 s
            while IFS= read -r s; do [ -z "${s}" ] && continue; found=$((found+1)); _chk_file "${s}" || ok=1
                head -n1 "${s}" | grep -q '^---' || { log_error "step06: ${s} no frontmatter"; ok=1; }
                grep -q '^name:' "${s}" || { log_error "step06: ${s} missing name:"; ok=1; }
                grep -q '^description:' "${s}" || { log_error "step06: ${s} missing description:"; ok=1; }
            done < <(find "${d}/skills" -mindepth 2 -maxdepth 2 -name 'SKILL.md' -type f 2>/dev/null | sort)
            [ "${found}" -gt 0 ] || { log_error "step06: no skills/*/SKILL.md"; ok=1; } ;;
        07) _chk_file "${d}/bin/oj-helper" || ok=1; _chk_file "${d}/bin/lib/contracts.sh" || ok=1
            _chk_file "${d}/.codex-plugin/plugin.json" || ok=1; _chk_file "${d}/hooks/hooks.json" || ok=1
            _chk_file "${d}/bootstrap.sh" || ok=1 ;;
        10) _chk_file "${d}/README.md" || ok=1; _chk_file "${d}/WHY.md" || ok=1 ;;
        11) _chk_file "${d}/CONDUCTOR.md" || ok=1 ;;
        *) log_warn "no verify for step ${step}" ;;
    esac
    return $ok
}

# ── static DATA-class emit (step-07) ─────────────────────────────────────────
static_emit() {
    [ "$1" = "07" ] || return 0
    local helper="${SCRIPT_DIR}/lib/emit-static-plugin-manifest.sh"
    [ -f "${helper}" ] || { log_error "emit helper missing: ${helper}"; return 1; }
    local version="0.0.1"; [ -f "${SPEC_DIR}/VERSION" ] && version=$(head -n1 "${SPEC_DIR}/VERSION" | tr -d ' \r\n\t')
    # shellcheck source=/dev/null
    . "${helper}"
    emit_plugin_json "${OUTPUT_DIR}" "${version}" >/dev/null
    emit_marketplace_json "${OUTPUT_DIR}" >/dev/null
    emit_hooks_json "${OUTPUT_DIR}" >/dev/null
    emit_contracts_sh "${OUTPUT_DIR}" >/dev/null
    emit_platform_defaults "${OUTPUT_DIR}" >/dev/null
    emit_bootstrap "${OUTPUT_DIR}" >/dev/null
    log_ok "  Static manifests emitted (.codex-plugin/, hooks/hooks.json, contracts.sh, platform-defaults.yaml, bootstrap.sh)"
}

# ── prompt build ─────────────────────────────────────────────────────────────
build_prompt() {
    local step="$1" pf content
    pf=$(resolve_prompt_file "${step}")
    [ -n "${pf}" ] && [ -f "${pf}" ] || die "no prompt file for step ${step} in ${SCRIPT_DIR}/steps/"
    content=$(sed \
        -e "s@/path/to/juntospec/@${SPEC_DIR}/@g" \
        -e "s@/path/to/juntogen/@${JUNTOGEN_ROOT}/@g" \
        "${pf}")
    if [ -n "${OJ_SOURCE}" ]; then
        content=$(printf '%s' "${content}" | sed -e "s@{OJ_SOURCE}@${OJ_SOURCE}@g" -e "s@/path/to/openjunto/@${OJ_SOURCE}/@g")
    fi
    local suffix=""
    if [ "${step}" = "00" ]; then
        suffix=" The Codex platform-defaults.yaml is at ${SCRIPT_DIR}/platform-defaults.yaml."
        [ -f "${OUTPUT_DIR}/platform-declaration.yaml" ] && suffix=" A platform-declaration.yaml exists — use declaration mode.${suffix}"
    fi
    # Many source prompts point at the Claude generator's prompts/specs, which are
    # dense with Claude-platform vocabulary. Without an explicit conversion contract the
    # engine leaves residue (haiku/sonnet/opus, "Task tool", "TeamCreate", "CLAUDE.md").
    # This mandatory replacement table applies to EVERY step's output.
    local repl='MANDATORY GLOBAL CONVERSION — source prompts reference the Claude Code platform. Convert EVERY occurrence in your generated output to the Codex binding; leave ZERO Claude-platform literals:
- "Task tool" / "spawn via the Task tool" -> a Codex subagent (defined at ${PLUGIN_ROOT}/.codex/agents/<role>.toml; spawned via /agent or auto-orchestration)
- "TeamCreate" / team formation / "swarm" -> parallel Codex subagents (Codex waits for all and returns a consolidated response)
- "SendMessage" / peer relay / inter-agent "Inform" -> NOT available on Codex; synthesis is handback-only
- model ids: haiku -> gpt-5.4-mini, sonnet -> gpt-5.3-codex, opus -> gpt-5.5 (and effort: routine=low, implementation=medium, reasoning=high, adversarial-reviewer=xhigh)
- "CLAUDE.md" (manager protocol) -> "CONDUCTOR.md"; "~/.claude/" -> "~/.codex/"; "${CLAUDE_PLUGIN_ROOT}" -> "${PLUGIN_ROOT}"; "claude plugin" install flow -> "codex plugin"
- "Claude Code" (the product/CLI) -> "Codex CLI"
KEEP unchanged (valid on Codex): the hook names "SessionStart" and "SubagentStart"; the abstract primitives Consult/Convene/Inform/Onboard.
Onboard binding (state accurately): the SubagentStart inject-profile hook is the PRIMARY, always-available path; native agent definitions (${PLUGIN_ROOT}/.codex/agents/<role>.toml) are an ENHANCEMENT that bootstrap.sh installs into ~/.codex/agents/. Codex does NOT auto-discover plugin-bundled agent definitions — do NOT claim native agent defs auto-load from the plugin.
After writing each file, RE-READ it and delete any remaining haiku/sonnet/opus, "Task tool", "TeamCreate", "SendMessage", "CLAUDE.md", "~/.claude/", "${CLAUDE_PLUGIN_ROOT}", or "${CODEX_PLUGIN_ROOT}" literal.'
    printf 'Execute the following generation prompt. Write all output files to the current working directory (%s). Plugin-internal path token is ${PLUGIN_ROOT}.%s\n\n%s\n\n%s' "${OUTPUT_DIR}" "${suffix}" "${repl}" "${content}"
}

# ── sentinels ────────────────────────────────────────────────────────────────
SENTINEL_DIR=""
sentinel_path(){ echo "${SENTINEL_DIR}/.step-$1.done"; }
should_skip(){ [ "${FORCE}" = "true" ] && return 1; [ -f "$(sentinel_path "$1")" ]; }

# ── run one step ─────────────────────────────────────────────────────────────
run_step() {
    local step="$1" mt desc log_file ptmp
    mt=$(step_max_turns "${step}"); desc=$(step_desc "${step}")
    echo ""; log_step "Step ${step}: ${desc}"
    log_info "  engine-model=${MODEL} max-turns=${mt}"
    ptmp=$(mktemp /tmp/oj-codex-step-${step}.XXXXXX)
    build_prompt "${step}" > "${ptmp}"
    mkdir -p "${OUTPUT_DIR}/prompts-built"; cp "${ptmp}" "${OUTPUT_DIR}/prompts-built/step-${step}.prompt"

    if [ "${DRY_RUN}" = "true" ]; then
        log_dry "would run claude (bare=$(use_bare_mode && echo yes || echo no)) model=${MODEL} max-turns=${mt} cwd=${OUTPUT_DIR}"
        log_dry "  prompt: $(head -c 100 "${ptmp}")..."
        rm -f "${ptmp}"; return 0
    fi

    log_file="${SENTINEL_DIR}/logs/step-${step}.log"; mkdir -p "${SENTINEL_DIR}/logs"
    local rc=0
    # stdin from /dev/null: claude -p has no TTY here and would otherwise wait on stdin.
    if use_bare_mode; then
        ( cd "${OUTPUT_DIR}" && IS_SANDBOX=1 claude --bare -p "$(cat "${ptmp}")" --model "${MODEL}" --dangerously-skip-permissions --max-turns "${mt}" </dev/null ) >"${log_file}" 2>&1 || rc=$?
    else
        ( cd "${OUTPUT_DIR}" && IS_SANDBOX=1 claude -p "$(cat "${ptmp}")" --model "${MODEL}" --dangerously-skip-permissions --max-turns "${mt}" \
            --append-system-prompt "${GENERATION_MODE_PROMPT}" --settings '{"disableAllHooks":true}' --disable-slash-commands </dev/null ) >"${log_file}" 2>&1 || rc=$?
    fi
    rm -f "${ptmp}"
    [ $rc -eq 0 ] || { log_error "  claude exited ${rc} (log: ${log_file})"; tail -5 "${log_file}" 2>/dev/null | sed 's/^/    /'; return 2; }

    static_emit "${step}" || return 2
    if verify_step "${step}"; then
        touch "$(sentinel_path "${step}")"; log_ok "  step ${step} verified"
    else
        log_error "  step ${step} verification FAILED (log: ${log_file})"; return 3
    fi
}

compute_steps() {
    if [ -n "${ONLY_STEPS}" ]; then echo "${ONLY_STEPS}" | tr ',' ' '; return; fi
    local started=false s out=""
    [ -z "${FROM_STEP}" ] && started=true
    for s in ${ALL_STEPS}; do [ "${s}" = "${FROM_STEP}" ] && started=true; [ "${started}" = "true" ] && out="${out} ${s}"; done
    echo "${out}"
}

main() {
    parse_args "$@"
    resolve_spec_dir
    SENTINEL_DIR="${OUTPUT_DIR}/.oj-codex-sentinels"; mkdir -p "${SENTINEL_DIR}"
    if [ "${DRY_RUN}" != "true" ]; then
        command -v claude >/dev/null 2>&1 || die "claude CLI not found (engine)"
        command -v jq >/dev/null 2>&1 || log_warn "jq not found — static manifest emit (step-07) will fail"
        # Root container: claude refuses --dangerously-skip-permissions as root unless
        # IS_SANDBOX=1 exactly. The ambient value may be unset (background tasks) or a
        # non-"1" string (e.g. "yes"), so force "1" when root. Ephemeral generation sandbox.
        if [ "$(id -u 2>/dev/null)" = "0" ]; then
            export IS_SANDBOX=1
            log_warn "running as root — forced IS_SANDBOX=1 for claude --dangerously-skip-permissions (sandboxed/ephemeral env)"
        fi
    fi
    local steps; steps=$(compute_steps)
    log_info "Steps: ${steps}"
    local s rc failed=0
    for s in ${steps}; do
        if should_skip "${s}"; then log_info "Step ${s}: skip (sentinel)"; continue; fi
        run_step "${s}" || { rc=$?; log_error "Step ${s} failed (rc=${rc})"; failed=1; break; }
    done
    echo ""
    [ ${failed} -eq 0 ] && log_ok "Pipeline complete → ${OUTPUT_DIR}" || die "Pipeline halted."
}

main "$@"
